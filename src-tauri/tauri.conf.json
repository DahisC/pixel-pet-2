{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "pixel-pet",
  "version": "0.1.0",
  "identifier": "com.pixelpet.app",
  "build": {
    "frontendDist": "../.output/public",
    "devUrl": "http://localhost:3005/desktop",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run generate"
  },
  "app": {
    "windows": [
      {
        "title": "Pixel Pet",
        "width": 128,
        "height": 128,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
